VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_or_anon_key

# Optional alias supported by the app for older Supabase projects:
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side scripts and Supabase Edge Functions only. Never prefix these with VITE_.
OPENROUTER_API_KEY=your_openrouter_api_key
SEED_USER_PASSWORD=choose_a_local_seed_password

# Supabase Edge Function secrets for secured buyer account changes:
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=WooSho Security <security@your_verified_domain>

# Supabase Edge Function secrets for Cloudinary buyer profile photos:
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
